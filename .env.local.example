# ─────────────────────────────────────────────────────────────
# VindiApp · Variables de entorno
# Copia este archivo a `.env.local` y rellena los valores reales.
# `.env.local` está en .gitignore y NUNCA debe subirse al repo.
# ─────────────────────────────────────────────────────────────

# URL del proyecto Supabase (Project Settings → API → Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Clave pública "anon" (Project Settings → API → Project API keys → anon public)
# Segura para el navegador: la protege Row Level Security.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Clave "service_role" (Project Settings → API → Project API keys → service_role)
# ⚠️ SECRETA. Salta toda la RLS. Úsala SOLO en el servidor.
# Nunca la expongas en el cliente ni con prefijo NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
